{
  "globalEndpoint": "global.azure-devices-provisioning.net",
  "idScope": "YOUR_ID_SCOPE_HERE",
  "registrationId": "YOUR_REGISTRATION_ID_HERE",
  "certPath": "/etc/nexuslocate/pki/device.crt",
  "keyPath": "/etc/nexuslocate/pki/device.key",
  "estServerUrl": "https://apim-dev-spotlight.azure-api.net/cert/est",
  "estBootstrapToken": "YOUR_DEV_BEARER_TOKEN",
  "tags": {
    "nexusLocate": {
      "siteName": "YOUR_SITE_NAME_HERE",
      "truckNumber": "YOUR_TRUCK_NUMBER_HERE"
    }
  },
  "batchSize": 10,
  "batchIntervalSeconds": 5,
  "mockDataEnabled": true,
  "mockDataIntervalSeconds": 30
}
