{
  "globalEndpoint": "global.azure-devices-provisioning.net",
  "idScope": "YOUR_ID_SCOPE_HERE",
  "registrationId": "YOUR_REGISTRATION_ID_HERE",
  "certPath": "/etc/azureiotpnp/device_cert.pem",
  "keyPath": "/etc/azureiotpnp/device_key.pem",
  "tags": {
    "nexusLocate": {
      "siteName": "YOUR_SITE_NAME_HERE",
      "truckNumber": "YOUR_TRUCK_NUMBER_HERE"
    }
  },
  "batchSize": 10,
  "batchIntervalSeconds": 5
}
